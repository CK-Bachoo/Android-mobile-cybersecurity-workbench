# ======================
# BUNKER .gitignore
# Android Mobile Cybersecurity Workbench
# ======================

# Secrets & Credentials
.secrets/
*.key
*.pem
*.pfx
*.password
github_pat.txt
*.env
.env*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Node.js / npm (CRITICAL FOR REPO SIZE OPTIMIZATION)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Logs
*.log
logs/
*.log.*

# Temporary / Cache
*.tmp
*.temp
.cache
*.swp
*~
.DS_Store
Thumbs.db

# Termux / Android specific
termux*
*.bak
*.backup

# Large files / Binaries
*.apk
*.bin
*.exe
*.dll

# Network captures (OPSEC - DO NOT COMMIT)
*.pcap
*.cap
*.pcapng

# HTML / Generated files (if big)
*.html.bak
god-mode.html.bak

# Virtual Environments
venv/
env/
ENV/

# IDE / Editor files
.vscode/
.idea/
*.code-workspace

# Git
.gitignore.bak

# Vault (OPSEC - sensitive operational data)
Vault/
Vault/Scans/
Vault/PCAPs/
Vault/Logs/
Vault/Evidence/

# Misc
*.sqlite3
*.db
